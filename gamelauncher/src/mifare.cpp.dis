boolean isndef_mifareclassic(Adafruit_PN532 *nfc) {
    // return true if the card is a mifare classic formatted with ndef
    // Use the default NDEF keys
    uint8_t keyb[6] = {0xD3, 0xF7, 0xD3, 0xF7, 0xD3, 0xF7};

    uint8_t uid[]     = {0, 0, 0, 0, 0, 0, 0};
    uint8_t uidLength = pn532_get_chip(nfc, uid);

    if (uidLength == 4) {
        // Check if this is an NDEF card (using first block of sector 1 from mifareclassic_formatndef.pde)
        // Must authenticate on the first key using 0xD3 0xF7 0xD3 0xF7 0xD3 0xF7
        return nfc->mifareclassic_AuthenticateBlock(uid, uidLength, 4, 0, keyb);
    }
    return false;
}

boolean formatndef_mifareclassic(Adafruit_PN532 *nfc) {
    // Use the default key during formatting
    uint8_t keya[6]   = {0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF};
    uint8_t uid[]     = {0, 0, 0, 0, 0, 0, 0};
    uint8_t uidLength = pn532_get_chip(nfc, uid);

    if (uidLength == 4) {
        // Try to format the card for NDEF data
        if (!nfc->mifareclassic_AuthenticateBlock(uid, uidLength, 0, 0, keya)) {
            Serial.println("Unable to authenticate block 0 to enable card formatting!");
            return false;
        }
        if (!nfc->mifareclassic_FormatNDEF()) {
            Serial.println("Unable to format the card for NDEF");
            return false;
        }
        Serial.println("Card has been formatted for NDEF data using MAD1");
        // Try to authenticate block 4 (first block of sector 1) using our key
        // Make sure the authentification process didn't fail
        if (!nfc->mifareclassic_AuthenticateBlock(uid, uidLength, 4, 0, keya)) {
            Serial.println("Authentication failed");
            return false;
        }
        // new ndef must have at least one record with 1 byte
        if (nfc->mifareclassic_WriteNDEFURI(1, NDEF_URIPREFIX_NONE, "_")) {
            Serial.print("NDEF empty URI Record written to sector 1");
            return true;
        }
        else {
            Serial.println("NDEF Record creation failed!");
            return false;
        }
    }

    Serial.println("This doesn't seem to be a Mifare Classic (UID length != 4 bytes)");
    return false;
}

boolean updatendef_mifareclassic(Adafruit_PN532 *nfc, const char *uri, uint8_t sector, uint8_t ndefprefix = NDEF_URIPREFIX_NONE) {
    // performs check if the card is formatted for ndef
    uint8_t keya[6]   = {0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF};
    uint8_t keyb[6]   = {0xD3, 0xF7, 0xD3, 0xF7, 0xD3, 0xF7};
    uint8_t uid[]     = {0, 0, 0, 0, 0, 0, 0};
    uint8_t uidLength = pn532_get_chip(nfc, uid);

    if (uidLength == 4) {
        // Sector 1 must authenticate on the first key using 0xD3 0xF7 0xD3 0xF7 0xD3 0xF7
        if (!nfc->mifareclassic_AuthenticateBlock(uid, uidLength, 4, 0, keyb)) {
            Serial.println("Unable to authenticate block 4. Is this card NDEF formatted?");
            return false;
        }
        Serial.println("NDEF Authentication succeeded");
        // Authenticate with the sector we are going to write to
        uint8_t block = (sector) << 2;
        if (!nfc->mifareclassic_AuthenticateBlock(uid, uidLength, block, 0, keyb)) {
            Serial.print("Unable to authenticate 4th block of sector ");
            Serial.print(sector);
            Serial.print(" (block ");
            Serial.print(block);
            Serial.println(") (using keyb, MIFARE_CMD_AUTH_A");
            return false;
        }
        // Authenticated seems to have worked
        if (strlen(uri) > 38) {
            Serial.println("URI is too long. Must be less than 38 characters!");
            return false;
        }
        Serial.println("Updating sector with URI as NDEF Message");

        // URI is within size limits ... write it to the card and report success/failure
        if (nfc->mifareclassic_WriteNDEFURI(sector, ndefprefix, uri)) {
            Serial.print("NDEF URI Record written to sector ");
            Serial.println(sector);
            return true;
        }
        else {
            Serial.println("NDEF Record creation failed!");
            return false;
        }
    }
    Serial.println("This doesn't seem to be a Mifare Classic (UID length != 4 bytes)");
    return false;
}

boolean erase_mifareclassic() {
    return false;
}

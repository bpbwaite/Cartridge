boolean erase_ntag2xx(Adafruit_PN532 *nfc, uint8_t userpage_stop, uint8_t userpage_start = 4) {
    // completely erase the chip, not needed since updatendef erases the data section anyways.
    uint8_t uid[]     = {0, 0, 0, 0, 0, 0, 0};
    uint8_t uidLength = pn532_get_chip(nfc, uid);

    if (uidLength == 7) {
        uint8_t pagebuf[4];
        Serial.print("Erasing ");
        Serial.print(userpage_start);
        Serial.print("..");
        Serial.println(userpage_stop);

        for (uint8_t i = userpage_start; i <= userpage_stop; i++) {
            memset(pagebuf, 0, 4);
            if (nfc->ntag2xx_WritePage(i, pagebuf)) {
                Serial.print("Erased page ");
                Serial.println(i);
            }
            else {
                Serial.println("Unable to write to the requested page!");
                return false;
            }
        }
        return true;
    }
    Serial.println("This doesn't seem to be an NTAG2xx (UID length != 7 bytes)");
    return false;
}

boolean formatndef_ntag2xx() {
